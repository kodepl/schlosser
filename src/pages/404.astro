---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../pbn-config';
---

<BaseLayout title="Page Not Found" description="Sorry, the page you are looking for does not exist." noindex={true}>
  <div class="text-center py-16">
    <h1 class="text-9xl font-bold text-slate-200 font-heading">404</h1>
    <h2 class="text-2xl font-bold text-slate-900 mt-4 mb-4">Page Not Found</h2>
    <p class="text-slate-600 mb-8">Sorry, but the page you are looking for does not exist.</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/" class="inline-flex items-center px-6 py-3 bg-primary-600 text-white font-medium rounded-xl hover:bg-primary-700 transition-colors">Home Page</a>
      <a href="/blog/" class="inline-flex items-center px-6 py-3 bg-white text-slate-700 border border-slate-300 font-medium rounded-xl hover:bg-slate-50 transition-colors">All Articles</a>
    </div>
  </div>
</BaseLayout>
