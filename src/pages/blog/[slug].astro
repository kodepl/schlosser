---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { LAYOUT_CONFIG, SITE_CONFIG } from '../../pbn-config';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { data } = post;
const title = data.seoTitle || data.title;
const description = data.seoDescription || data.description;
const readingTime = data.readingTime || Math.ceil((post.body?.split(/\s+/).length || 0) / 200);
const formattedDate = data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const breadcrumbs = [{ name: 'Articles', url: '/blog/' }, { name: data.title, url: `/blog/${post.slug}/`, current: true }];
const hasTags = data.tags && data.tags.length > 0;
---

<BaseLayout title={title} description={description} type="article" article={post} image={data.coverImage} imageAlt={data.coverAlt} breadcrumbs={breadcrumbs} lastmod={data.updatedDate?.toISOString() || data.pubDate.toISOString()}>
  <Breadcrumbs items={breadcrumbs} />
  <header class="article-header mb-8">
    {LAYOUT_CONFIG.showTags && hasTags && (
      <div class="flex flex-wrap gap-2 mb-4">
        {data.tags.map(tag => <a href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-')}/`} class="inline-flex items-center px-3 py-1 text-sm font-medium text-primary-600 bg-primary-50 rounded-full hover:bg-primary-100 transition-colors">{tag}</a>)}
      </div>
    )}
    <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-slate-900 leading-tight mb-4 font-heading">{data.title}</h1>
    {data.description && <p class="text-xl text-slate-600 leading-relaxed">{data.description}</p>}
    <div class="flex flex-wrap items-center gap-4 mt-6 pt-6 border-t border-slate-100 text-sm text-slate-500">
      {LAYOUT_CONFIG.showAuthor && <span class="font-medium text-slate-700">{data.author}</span>}
      {LAYOUT_CONFIG.showDates && <time datetime={data.pubDate.toISOString()}>{formattedDate}</time>}
      {LAYOUT_CONFIG.showReadingTime && <span>{readingTime} min read</span>}
    </div>
  </header>
  {data.coverImage && (
    <figure class="article-image mb-8">
      <img src={data.coverImage} alt={data.coverAlt || data.title} width={1200} height={675} class="w-full h-auto rounded-xl shadow-lg" loading="eager" decoding="async" />
      {data.coverAlt && <figcaption class="text-center text-sm text-slate-500 mt-3">{data.coverAlt}</figcaption>}
    </figure>
  )}
  <article class="prose prose-lg max-w-none"><Content /></article>
  {LAYOUT_CONFIG.showTags && hasTags && (
    <footer class="article-footer mt-12 pt-8 border-t border-slate-200">
      <div class="flex flex-wrap items-center gap-3">
        <span class="text-slate-600 font-medium">Tags:</span>
        {data.tags.map(tag => <a href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-')}/`} class="inline-flex items-center px-3 py-1 text-sm text-slate-600 bg-slate-100 rounded-full hover:bg-slate-200 transition-colors">#{tag}</a>)}
      </div>
    </footer>
  )}
  <RelatedPosts currentPost={post} />
</BaseLayout>
