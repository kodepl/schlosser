---
import type { CollectionEntry } from 'astro:content';
import { LAYOUT_CONFIG } from '../pbn-config';

interface Props { post: CollectionEntry<'blog'>; variant?: 'default' | 'horizontal' | 'compact' | 'featured'; }
const { post, variant = 'default' } = Astro.props;
const { data, slug } = post;
const readingTime = data.readingTime || Math.ceil((post.body?.split(/\s+/).length || 0) / 200);
const formattedDate = data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const postUrl = `/blog/${slug}/`;
const cardClasses = `${LAYOUT_CONFIG.htmlStructure.articleClass} ${LAYOUT_CONFIG.colors.cardBg} ${LAYOUT_CONFIG.colors.cardBorder} rounded-xl overflow-hidden transition-all hover:shadow-lg hover:-translate-y-1`;
---

{variant === 'default' && (
  <article class={cardClasses}>
    {data.coverImage && (
      <a href={postUrl} class="block aspect-video overflow-hidden">
        <img src={data.coverImage} alt={data.coverAlt || data.title} width={600} height={340} class="w-full h-full object-cover transition-transform duration-300 hover:scale-105" loading="lazy" />
      </a>
    )}
    <div class="p-5">
      {LAYOUT_CONFIG.showTags && data.tags && data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-3">
          {data.tags.slice(0, 3).map(tag => <a href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-')}/`} class="text-xs font-medium text-primary-600 bg-primary-50 px-2 py-1 rounded-full hover:bg-primary-100 transition-colors">{tag}</a>)}
        </div>
      )}
      <h2 class="text-xl font-bold text-slate-900 mb-2 line-clamp-2 font-heading"><a href={postUrl} class="hover:text-primary-600 transition-colors">{data.title}</a></h2>
      {data.description && <p class="text-slate-600 text-sm line-clamp-3 mb-4">{data.description}</p>}
      <div class="flex items-center text-xs text-slate-500 gap-4">
        {LAYOUT_CONFIG.showDates && <time datetime={data.pubDate.toISOString()}>{formattedDate}</time>}
        {LAYOUT_CONFIG.showReadingTime && <span>{readingTime} min read</span>}
      </div>
    </div>
  </article>
)}

{variant === 'horizontal' && (
  <article class={`${cardClasses} flex flex-col md:flex-row`}>
    {data.coverImage && (
      <a href={postUrl} class="block md:w-1/3 aspect-video md:aspect-square overflow-hidden">
        <img src={data.coverImage} alt={data.coverAlt || data.title} width={400} height={300} class="w-full h-full object-cover transition-transform duration-300 hover:scale-105" loading="lazy" />
      </a>
    )}
    <div class="p-5 md:w-2/3 flex flex-col justify-center">
      {LAYOUT_CONFIG.showTags && data.tags && data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-3">
          {data.tags.slice(0, 3).map(tag => <a href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-')}/`} class="text-xs font-medium text-primary-600 bg-primary-50 px-2 py-1 rounded-full hover:bg-primary-100 transition-colors">{tag}</a>)}
        </div>
      )}
      <h2 class="text-xl font-bold text-slate-900 mb-2 font-heading"><a href={postUrl} class="hover:text-primary-600 transition-colors">{data.title}</a></h2>
      {data.description && <p class="text-slate-600 text-sm line-clamp-2 mb-4">{data.description}</p>}
      <div class="flex items-center text-xs text-slate-500 gap-4">
        {LAYOUT_CONFIG.showAuthor && <span>{data.author}</span>}
        {LAYOUT_CONFIG.showDates && <time datetime={data.pubDate.toISOString()}>{formattedDate}</time>}
        {LAYOUT_CONFIG.showReadingTime && <span>{readingTime} min read</span>}
      </div>
    </div>
  </article>
)}

{variant === 'featured' && (
  <article class={`${cardClasses} relative`}>
    {data.coverImage && (
      <a href={postUrl} class="block aspect-[16/9] overflow-hidden">
        <img src={data.coverImage} alt={data.coverAlt || data.title} width={1200} height={675} class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent" />
      </a>
    )}
    <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
      {LAYOUT_CONFIG.showTags && data.tags && data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-3">
          {data.tags.slice(0, 3).map(tag => <a href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-')}/`} class="text-xs font-medium text-white bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full hover:bg-white/30 transition-colors">{tag}</a>)}
        </div>
      )}
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3 font-heading"><a href={postUrl} class="hover:text-slate-200 transition-colors">{data.title}</a></h2>
      {data.description && <p class="text-slate-200 text-sm md:text-base line-clamp-2 mb-4 max-w-2xl">{data.description}</p>}
      <div class="flex items-center text-sm text-slate-300 gap-4">
        {LAYOUT_CONFIG.showAuthor && <span>{data.author}</span>}
        {LAYOUT_CONFIG.showDates && <time datetime={data.pubDate.toISOString()}>{formattedDate}</time>}
        {LAYOUT_CONFIG.showReadingTime && <span>{readingTime} min read</span>}
      </div>
    </div>
  </article>
)}
