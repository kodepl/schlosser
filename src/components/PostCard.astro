---
import type { CollectionEntry } from 'astro:content';
import { LAYOUT_CONFIG } from '../pbn-config';

interface Props { post: CollectionEntry<'blog'>; variant?: 'default' | 'horizontal' | 'compact' | 'featured'; }
const { post, variant = 'default' } = Astro.props;
const { data, slug } = post;
const readingTime = data.readingTime || Math.ceil((post.body?.split(/\s+/).length || 0) / 200);
const formattedDate = data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const postUrl = `/blog/${slug}`;
---

{variant === 'default' && (
  <article class="bg-slate-900/30 border border-amber-900/20 rounded overflow-hidden hover:border-amber-900/40 transition-all group">
    {data.coverImage && (
      <a href={postUrl} class="block aspect-video overflow-hidden">
        <img src={data.coverImage} alt={data.coverAlt || data.title} width={600} height={340} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
      </a>
    )}
    <div class="p-6">
      {LAYOUT_CONFIG.showTags && data.tags && data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-3">
          {data.tags.slice(0, 3).map(tag => <span class="text-xs text-amber-500/70 tracking-wider uppercase">{tag}</span>)}
        </div>
      )}
      <h2 class="text-xl font-heading font-normal text-white mb-2 group-hover:text-amber-400 transition-colors line-clamp-2">
        <a href={postUrl}>{data.title}</a>
      </h2>
      {data.description && <p class="text-slate-500 text-sm line-clamp-3 mb-4">{data.description}</p>}
      <div class="flex items-center text-xs text-slate-600 gap-4">
        {LAYOUT_CONFIG.showDates && <time datetime={data.pubDate.toISOString()}>{formattedDate}</time>}
        {LAYOUT_CONFIG.showReadingTime && <span>{readingTime} min read</span>}
      </div>
    </div>
  </article>
)}

{variant === 'horizontal' && (
  <article class="bg-slate-900/30 border border-amber-900/20 rounded overflow-hidden hover:border-amber-900/40 transition-all group flex flex-col md:flex-row">
    {data.coverImage && (
      <a href={postUrl} class="block md:w-1/3 aspect-video md:aspect-square overflow-hidden">
        <img src={data.coverImage} alt={data.coverAlt || data.title} width={400} height={300} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
      </a>
    )}
    <div class="p-6 md:w-2/3 flex flex-col justify-center">
      {LAYOUT_CONFIG.showTags && data.tags && data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-3">
          {data.tags.slice(0, 3).map(tag => <span class="text-xs text-amber-500/70 tracking-wider uppercase">{tag}</span>)}
        </div>
      )}
      <h2 class="text-xl font-heading font-normal text-white mb-2 group-hover:text-amber-400 transition-colors">
        <a href={postUrl}>{data.title}</a>
      </h2>
      {data.description && <p class="text-slate-500 text-sm line-clamp-2 mb-4">{data.description}</p>}
      <div class="flex items-center text-xs text-slate-600 gap-4">
        {LAYOUT_CONFIG.showAuthor && <span>{data.author}</span>}
        {LAYOUT_CONFIG.showDates && <time datetime={data.pubDate.toISOString()}>{formattedDate}</time>}
        {LAYOUT_CONFIG.showReadingTime && <span>{readingTime} min read</span>}
      </div>
    </div>
  </article>
)}

{variant === 'featured' && (
  <article class="relative rounded overflow-hidden group">
    {data.coverImage && (
      <a href={postUrl} class="block aspect-[16/9] overflow-hidden">
        <img src={data.coverImage} alt={data.coverAlt || data.title} width={1200} height={675} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/60 to-transparent" />
      </a>
    )}
    <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
      {LAYOUT_CONFIG.showTags && data.tags && data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-3">
          {data.tags.slice(0, 3).map(tag => <span class="text-xs text-amber-400 tracking-wider uppercase">{tag}</span>)}
        </div>
      )}
      <h2 class="text-2xl md:text-3xl font-heading font-normal text-white mb-3 group-hover:text-amber-400 transition-colors">
        <a href={postUrl}>{data.title}</a>
      </h2>
      {data.description && <p class="text-slate-300 text-sm md:text-base line-clamp-2 mb-4 max-w-2xl">{data.description}</p>}
      <div class="flex items-center text-sm text-slate-500 gap-4">
        {LAYOUT_CONFIG.showAuthor && <span>{data.author}</span>}
        {LAYOUT_CONFIG.showDates && <time datetime={data.pubDate.toISOString()}>{formattedDate}</time>}
        {LAYOUT_CONFIG.showReadingTime && <span>{readingTime} min read</span>}
      </div>
    </div>
  </article>
)}
