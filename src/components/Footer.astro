---
import { SITE_CONFIG, LAYOUT_CONFIG } from '../pbn-config';
const currentYear = new Date().getFullYear();
---

{LAYOUT_CONFIG.footerStyle !== 'none' && (
  <footer class={`${LAYOUT_CONFIG.colors.footerBg} ${LAYOUT_CONFIG.colors.footerText} mt-16`}>
    {LAYOUT_CONFIG.footerStyle === 'compact' && (
      <div class="container mx-auto px-4 py-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <div>
            <span class="text-white font-bold text-lg font-heading">{SITE_CONFIG.name}</span>
            <p class="text-slate-400 text-sm mt-1">{SITE_CONFIG.description.slice(0, 80)}...</p>
          </div>
          <nav class="flex items-center gap-6 text-sm">
            <a href="/" class="hover:text-white transition-colors">Home</a>
            <a href="/blog/" class="hover:text-white transition-colors">Articles</a>
            <a href="/tag/technology/" class="hover:text-white transition-colors">Tech</a>
            <a href="/tag/science/" class="hover:text-white transition-colors">Science</a>
          </nav>
        </div>
        <div class="border-t border-slate-700 mt-6 pt-6 text-center text-sm text-slate-500">
          <p>&copy; {currentYear} {SITE_CONFIG.organization.name}. All rights reserved.</p>
        </div>
      </div>
    )}
  </footer>
)}
