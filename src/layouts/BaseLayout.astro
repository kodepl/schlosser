---
import '../styles/global.css';
import { SITE_CONFIG, LAYOUT_CONFIG } from '../pbn-config';
import SeoHead from '../components/SeoHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string; description?: string; type?: 'website' | 'article' | 'blog' | 'page';
  image?: string; imageAlt?: string; article?: CollectionEntry<'blog'>;
  canonicalUrl?: string; noindex?: boolean; lastmod?: string;
  breadcrumbs?: Array<{ name: string; url: string }>; extraMeta?: Array<{ name: string; content: string }>;
}
const { title, description, type = 'website', image, imageAlt, article, canonicalUrl, noindex, lastmod, breadcrumbs, extraMeta } = Astro.props;
const wrapperClass = LAYOUT_CONFIG.htmlStructure.wrapperClass;
const mainId = LAYOUT_CONFIG.htmlStructure.mainId;
---

<!DOCTYPE html>
<html lang={SITE_CONFIG.language} class="scroll-smooth dark">
<head>
  <SeoHead title={title} description={description} type={type} image={image} imageAlt={imageAlt} article={article} canonicalUrl={canonicalUrl} noindex={noindex} lastmod={lastmod} breadcrumbs={breadcrumbs} extraMeta={extraMeta} />
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700;900&family=Work+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <!-- Umami Analytics -->
  <script defer src="https://cloud.umami.is/script.js" data-website-id="7d4093d4-b457-4c1e-abde-64f9f67f354c"></script>
  <link rel="preconnect" href="https://picsum.photos">
</head>
<body class="font-body bg-surface text-text-primary antialiased min-h-screen flex flex-col dark">
  <Header />
  <div class={`${wrapperClass} flex-1`}>
    <div class="container mx-auto px-4 sm:px-8 lg:px-16 py-12 max-w-5xl">
      <main id={mainId}>
        <slot />
      </main>
    </div>
  </div>
  <Footer />
</body>
</html>
